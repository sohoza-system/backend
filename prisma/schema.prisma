generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String?
  password      String?
  role          Role      @default(USER)
  provider      String    @default("local") // "local" or "google"
  providerId    String?   @unique
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  phone         String?
  profileImage  String?
  bio           String?
  lastLogin     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Security
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  emailVerifyToken     String?

  posts         Post[]
  comments      Comment[]
  postLikes     PostLike[]
  refreshTokens RefreshToken[]
  media         Media[]
  friends       User[]         @relation("UserFriends")
  friendOf      User[]         @relation("UserFriends")

  @@map("user")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  email     String   @unique
  bio       String?
  image     String?
  status    String   @default("active")
  order     Int      @default(0)
  socials   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teammember")
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  icon        String?
  features    String[]
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("service")
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  description String? // optional short preview
  content     String
  imageUrl    String?
  published   Boolean?  @default(false)
  status      String    @default("published")
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  authorId Int
  author   User @relation(fields: [authorId], references: [id])

  comments   Comment[]
  categories PostCategory[]
  likes      PostLike[]

  @@map("post")
}

model PostLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("postlike")
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  authorId Int
  postId   Int

  author User @relation(fields: [authorId], references: [id])
  post   Post @relation(fields: [postId], references: [id])

  @@map("comment")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  posts PostCategory[]

  @@map("category")
}

model PostCategory {
  postId     Int
  categoryId Int

  post     Post     @relation(fields: [postId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([postId, categoryId])
  @@map("postcategory")
}

model Activity {
  id          Int      @id @default(autoincrement())
  userId      Int?
  type        String
  description String
  createdAt   DateTime @default(now())

  @@map("activity")
}

model Visit {
  id         Int      @id @default(autoincrement())
  pagePath   String
  deviceType String?
  source     String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("visit")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("unread") // unread, read, replied
  createdAt DateTime @default(now())

  @@map("contactmessage")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("refreshtoken")
}

model Settings {
  id              Int      @id @default(1)
  siteName        String   @default("Sohoza System")
  siteDescription String?
  contactEmail    String?
  contactPhone    String?
  socialLinks     Json?
  maintenanceMode Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@map("settings")
}

model Media {
  id        Int      @id @default(autoincrement())
  url       String
  publicId  String?
  fileName  String?
  fileType  String?
  fileSize  Int?
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("media")
}

model NewsletterSubscription {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  isActive          Boolean   @default(true)
  verificationToken String?
  isVerified        Boolean   @default(false)
  verifiedAt        DateTime?
  unsubscribeToken  String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("newslettersubscription")
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
}
