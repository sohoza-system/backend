generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String?
  password      String
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  phone         String?
  profileImage  String?
  bio           String?
  lastLogin     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  friends       User[]    @relation("UserFriends")
  friendOf      User[]    @relation("UserFriends")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  email     String   @unique
  bio       String?
  image     String?
  status    String   @default("active")
  socials   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  icon        String?
  features    String[]
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  status    String   @default("published")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id          Int      @id @default(autoincrement())
  type        String
  description String
  createdAt   DateTime @default(now())
}

model Visit {
  id         Int      @id @default(autoincrement())
  pagePath   String
  deviceType String
  source     String
  createdAt  DateTime @default(now())
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
}
